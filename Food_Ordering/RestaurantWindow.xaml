<Window x:Class="Food_Ordering.RestaurantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý món ăn" Height="500" Width="900">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Khu tìm nhà hàng theo OwnerId + khu nhập món -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="OwnerId:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="txtOwnerIdSearch" Width="100" Margin="0,0,10,0"/>
                <Button x:Name="btnFindOwner" Content="Tìm theo OwnerId" Click="btnFindOwner_Click" Margin="0,0,8,0"/>
                <Button x:Name="btnLoadMine" Content="Tải nhà hàng của tôi" Click="btnLoadMine_Click"/>
            </StackPanel>

            <!-- Nhập thông tin món ăn -->
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Tên món ăn"/>
                    <TextBox x:Name="txtName" Width="250"/>
                </StackPanel>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Giá"/>
                    <TextBox x:Name="txtPrice" Width="120"/>
                </StackPanel>

                <Button x:Name="btnAdd" Content="Thêm món" Width="100" Margin="0,20,10,0" Click="btnAdd_Click"/>
                <Button x:Name="btnUpdate" Content="Cập nhật món" Width="120" Margin="0,20,10,0" Click="btnUpdate_Click"/>
                <Button x:Name="btnDelete" Content="Xóa món" Width="100" Margin="0,20,10,0" Click="btnDelete_Click"/>
                <Button x:Name="btnSoldOut" Content="Hết trong ngày" Width="120" Margin="0,20,10,0" Click="btnSoldOut_Click"/>
                <Button x:Name="btnRestore" Content="Mở lại" Width="100" Margin="0,20,0,0" Click="btnRestore_Click"/>
            </StackPanel>
        </StackPanel>

        <!-- Danh sách món ăn -->
        <DataGrid x:Name="dgMenu" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DataGrid_SelectionChanged" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên món" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price}" Width="120"/>
                <DataGridCheckBoxColumn Header="Còn hàng" Binding="{Binding IsAvailable}" Width="100" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
