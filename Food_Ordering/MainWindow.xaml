<Window x:Class="Food_Ordering.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Đặt Món - Customer" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="15">
            <TextBlock Text="1. Chọn Nhà Hàng" FontSize="18" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>
            <ComboBox x:Name="cbRestaurants" DisplayMemberPath="Name" 
                      SelectionChanged="CbRestaurants_SelectionChanged" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="2. Thực Đơn" FontSize="18" FontWeight="Bold" Margin="0,0,0,5" Foreground="#2C3E50"/>
            <ListBox x:Name="lbFoodItems" Height="300" BorderBrush="#BDC3C7" BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="450" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat={}{0:N0} VNĐ}" 
                                       Foreground="#27AE60" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Content="Thêm vào giỏ hàng" Background="#3498DB" Foreground="White" 
                    FontWeight="Bold" Height="40" Margin="0,15,0,0" Click="BtnAddToCart_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <Border Grid.Column="1" Background="#ECF0F1" CornerRadius="5" Margin="10">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10"/>

                <Button x:Name="btnLogout" 
                    Content="🚪 Đăng xuất" 
                    Click="BtnLogout_Click" 
                    Background="#E74C3C" Foreground="White" 
                    Padding="10,5" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="15"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="📜 Xem Lịch sử đơn hàng" 
                        Click="BtnHistory_Click"
                        Background="#95A5A6" Foreground="White" 
                        FontWeight="Bold" Height="35" Margin="0,0,0,15">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Separator Margin="0,0,0,10" Background="#BDC3C7"/>

                <TextBlock Text="🛒 Giỏ hàng của bạn" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2C3E50"/>

                <DataGrid x:Name="dgCart" AutoGenerateColumns="False" Height="250" 
                CanUserAddRows="False" IsReadOnly="True" Background="White"
                BorderBrush="#DCDDE1" RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên món" Binding="{Binding Name}" Width="*"/>

                        <DataGridTemplateColumn Header="Số lượng" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="-" Width="25" Height="25" Click="BtnDecrease_Click" Background="#BDC3C7" BorderThickness="0"/>
                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold"/>
                                        <Button Content="+" Width="25" Height="25" Click="BtnIncrease_Click" Background="#BDC3C7" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N0}đ}" Width="80"/>

                        <DataGridTemplateColumn Header="Xóa" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="❌" Click="BtnRemove_Click" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Separator Margin="0,15" Background="#BDC3C7"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Tổng cộng: " FontSize="16" VerticalAlignment="Bottom"/>
                    <TextBlock x:Name="txtTotal" Text="0 VNĐ" FontSize="20" FontWeight="Bold" Foreground="#E67E22"/>
                </StackPanel>

                <Button Content="THANH TOÁN NGAY" Margin="0,20,0,0" Height="50" 
                        Background="#E67E22" Foreground="White" FontWeight="Bold" FontSize="16" BorderThickness="0"
                        Click="BtnCheckout_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>