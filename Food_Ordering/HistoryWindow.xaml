<Window x:Class="Food_Ordering.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lịch Sử Đơn Hàng" Height="600" Width="900" Loaded="Window_Loaded" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ĐƠN HÀNG CỦA TÔI" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
            <Button Content="🔄 Làm mới trạng thái" Click="BtnRefresh_Click" HorizontalAlignment="Right" 
                    Padding="15,5" Background="#3498DB" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </DockPanel>

        <DataGrid Grid.Row="1" x:Name="dgOrders" AutoGenerateColumns="False" 
                  CanUserAddRows="False" IsReadOnly="True" 
                  SelectionChanged="DgOrders_SelectionChanged" Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Đơn" Binding="{Binding OrderId}" Width="60"/>
                <DataGridTextColumn Header="Nhà hàng" Binding="{Binding Restaurant.Name}" Width="150"/>
                <DataGridTextColumn Header="Ngày đặt" Binding="{Binding CreatedAt, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="130"/>
                <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat=\{0:N0\}đ}" Width="90"/>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="110"/>
                <DataGridTextColumn Header="Shipper" Binding="{Binding Shipper.FullName}" Width="120"/>

                <DataGridTemplateColumn Header="Thao tác" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Hủy đơn" Margin="2" Padding="8,2" Background="#E74C3C" Foreground="White"
                                        Click="BtnCancelOrder_Click" Cursor="Hand"/>
                                <Button Content="Đã nhận hàng" Margin="2" Padding="8,2" Background="#27AE60" Foreground="White"
                                        Click="BtnReceived_Click" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="CHI TIẾT MÓN ĂN" FontWeight="Bold" Margin="0,15,0,5" Foreground="#34495E"/>
        <ListBox Grid.Row="3" x:Name="lbOrderDetails" BorderBrush="#DCDDE1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="800">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FoodName}" Width="300" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Quantity, StringFormat='x\{0\}'}" Width="100"/>
                            <TextBlock Text="{Binding FoodPrice, StringFormat=\{0:N0\}đ}" Foreground="#27AE60" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>