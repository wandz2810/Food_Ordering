<Window x:Class="Food_Ordering.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Food_Ordering"
        mc:Ignorable="d"
        ResizeMode ="NoResize"
        Title="Login" Height="900" Width="800">

    <Window.Resources>
        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E86AB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B6CA8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#145080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input Style -->
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Tab Item Style -->
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#2E86AB"/>
                                <Setter Property="Foreground" Value="#2E86AB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2E86AB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" Padding="30,20" Margin="0,0,0,-256">
        <StackPanel>

            <!-- App Title -->
            <TextBlock Text="Đăng nhập"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#222222"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Tab Control -->
            <TabControl Name="LoginTabControl" BorderThickness="0" Background="Transparent" Padding="0" SelectedIndex="0">

                <!-- ── LOGIN TAB ── -->
                <TabItem Header="Đăng nhập" Style="{StaticResource TabStyle}">
                    <StackPanel Margin="0,24,0,0">

                        <TextBlock Text="Email" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtEmail"
                                 Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Mật khẩu" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="txtPassword"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,24"/>

                        <Button Content="Login"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="40"
                                Click="btnLogin_Click"/>
                    </StackPanel>
                </TabItem>

                <!-- ── REGISTER TAB ── -->
                <TabItem Header="Đăng ký" Style="{StaticResource TabStyle}">
                    <StackPanel Margin="0,24,0,0">

                        <TextBlock Text="Email" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtRegEmail"
                                 Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Mật khẩu" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="txtRegPassword"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,14"/>

                        <TextBlock Text="Confirm Password" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="txtRegConfirmPassword"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,24"/>


                        <TextBlock Text="Full Name" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtRegFullname"
                                 Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Phone Number" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtRegPhone"
                                 Style="{StaticResource InputStyle}"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Register as" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                        <ComboBox Name="cbRegRole" FontSize="24" Margin="0, 0, 0,24" SelectionChanged="cbRegRole_SelectionChanged">
                        </ComboBox>

                        <GroupBox Name="grCustomer" Visibility="Hidden">
                            <StackPanel>
                                <TextBlock Text="Address" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtRegAdress"
                                     Style="{StaticResource InputStyle}"
                                     Margin="0,0,0,14"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Name="grShipper" Visibility="Hidden">
                            <StackPanel>
                                <TextBlock Text="License Plate" FontSize="12" Foreground="#555555" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtLicensePlate"
                                    Style="{StaticResource InputStyle}"
                                    Margin="0,0,0,14"/>
                            </StackPanel>
                        </GroupBox>

                        <Button Content="Register"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="40"
                                Click="btnRegister_Click"/>
                    </StackPanel>
                </TabItem>

            </TabControl>
        </StackPanel>
    </Border>
</Window>
