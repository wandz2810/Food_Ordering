<Window x:Class="Food_Ordering.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác Nhận Đơn Hàng" Height="650" Width="450" WindowStartupLocation="CenterOwner">

    <Border Padding="20" Background="#F8F9FA">
        <StackPanel>
            <TextBlock Text="THÔNG TIN THANH TOÁN" FontSize="22" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Họ và tên:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtFullName" Height="30" VerticalContentAlignment="Center" Margin="0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtEmail" Height="30" VerticalContentAlignment="Center" Margin="0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Số điện thoại:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtPhone" Height="30" VerticalContentAlignment="Center" Margin="0,5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Địa chỉ giao:" VerticalAlignment="Center" Margin="0,10"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtAddress" Height="30" VerticalContentAlignment="Center" Margin="0,5"/>
            </Grid>

            <Separator Margin="0,20"/>

            <TextBlock Text="ĐƠN HÀNG CỦA BẠN" FontWeight="Bold" FontSize="16" Margin="0,0,0,10" Foreground="#34495E"/>

            <Border Background="White" BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="5">
                <ListBox x:Name="lbSummary" Height="150" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="360" Margin="5">
                                <TextBlock Text="{Binding Name}" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Price, StringFormat={}{0:N0}đ}" HorizontalAlignment="Right" Foreground="#27AE60"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
                <TextBlock Text="Tổng cộng: " FontSize="18" VerticalAlignment="Bottom"/>
                <TextBlock x:Name="txtTotal" Text="0 VNĐ" FontSize="24" FontWeight="Bold" Foreground="#E67E22"/>
            </StackPanel>

            <Button Content="XÁC NHẬN &amp; GỬI SHIPPER" Height="50" FontSize="16" 
                    Background="#E67E22" Foreground="White" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="BtnConfirm_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="25"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>